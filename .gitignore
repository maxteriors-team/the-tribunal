# Environment variables
.env
.env.local
.env.*.local
.env*
!.env.example

# Local secret material (never commit)
meta_ads.rtf
Telynx API.rtf
# Catch-all for credential/notes dumps pasted into the repo root
*.rtf

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# Misc
*.pem

# Scratch component captures
card-*.html
navigation-*.html
generic-component-*.html

# Agent perception probes (.ezcoder/eyes): the authored probe scripts
# (http.sh, logs.sh, mail.sh) and manifest.json are canonical tracked assets.
# Ignore only runtime-copied helpers, downloaded binaries, and captured state.
.ezcoder/eyes/out/
.ezcoder/eyes/state/
.ezcoder/eyes/bin/
.ezcoder/eyes/recordings/
.ezcoder/eyes/auth/
.ezcoder/eyes/remote.json
.ezcoder/eyes/_lib.sh
.ezcoder/eyes/_redact.sh

# Agent upload scratch (pasted screenshots/files); never part of the project.
.ezcoder/uploads/
.ezcoder/screenshots/

# Legacy agent toolchains — consolidated into .ezcoder/ (see CLAUDE.md).
# Ignore the whole legacy trees so stray IDE/agent configs don't reintroduce them.
.claude/
.gg/

# Deploy / build tool caches
.railway
.turbo/
.parcel-cache/

# Storybook / test artifacts
storybook-static/
playwright-report/
test-results/
*.lcov

# Visual-preview suite output (generated PNGs, gallery, saved auth state)
visual-snapshots/
.auth/

# Local env overrides
.env.production.local
.env.development.local

# Local databases
*.sqlite
*.db

# Local pg_dump output from `make db.backup.local`
backend/backups/
*.dump
.local-bundles/
