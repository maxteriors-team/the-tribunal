# Scratch component captures
card-*.html
navigation-*.html
generic-component-*.html

# Agent perception probes — runtime artifacts only.
# Probe scripts live under .gg/eyes/ (canonical); .ezcoder/eyes/ holds the
# manifest + journal that point at them. Both contain transient state
# (screenshots, captured mail, mailpit binary) so the whole tree is ignored.
.ezcoder/eyes/
.gg/eyes/

# Legacy agent toolchains — consolidated into .ezcoder/ (see CLAUDE.md).
# Keep these ignored so stray IDE configs don't re-introduce duplicates.
.claude/commands/
.gg/commands/
.gg/plans/

# Worktrees / agent scratch
.claude/worktrees/

# Python caches outside backend
scripts/__pycache__/

# Deploy / build tool caches
.railway
.turbo/
.parcel-cache/

# Storybook / test artifacts
storybook-static/
playwright-report/
test-results/
*.lcov

# Local env overrides
.env.production.local
.env.development.local

# Local databases
*.sqlite
*.db

# Local pg_dump output from `make db.backup.local`
backend/backups/
*.dump
