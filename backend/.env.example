# Database
# POSTGRES_PASSWORD is consumed by docker-compose.yml (Postgres container init).
# Keep it in sync with the password embedded in DATABASE_URL below.
POSTGRES_PASSWORD=aicrm_dev_password
DATABASE_URL=postgresql+asyncpg://aicrm:aicrm_dev_password@localhost:5432/aicrm
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# Redis
REDIS_URL=redis://localhost:6379/0

# Security
SECRET_KEY=your-secret-key-change-in-production
ENCRYPTION_KEY=your-fernet-encryption-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
TRUSTED_PROXIES=["127.0.0.1", "::1"]

# OpenAI
OPENAI_API_KEY=sk-your-openai-key
OPENAI_TIMEOUT=60

# Telnyx
TELNYX_API_KEY=KEY-your-telnyx-key
TELNYX_WEBHOOK_SECRET=your-webhook-secret
TELNYX_PUBLIC_KEY=your-telnyx-public-key
SKIP_WEBHOOK_VERIFICATION=false
TELNYX_CONNECTION_ID=your-connection-id

# Cal.com
CALCOM_API_KEY=cal_live_your-calcom-key
CALCOM_WEBHOOK_SECRET=your-calcom-webhook-secret

# ElevenLabs (optional, for custom voices)
ELEVENLABS_API_KEY=your-elevenlabs-key

# xAI (Grok)
XAI_API_KEY=xai-your-grok-key

# Resend
RESEND_API_KEY=re_your-resend-key
RESEND_FROM_EMAIL=noreply@example.com
RESEND_FROM_NAME=AI CRM
RESEND_WEBHOOK_SECRET=whsec_your-resend-webhook-secret

# Expo Push Notifications
EXPO_ACCESS_TOKEN=your-expo-access-token

# Google Places API
GOOGLE_PLACES_API_KEY=your-google-places-key

# App
DEBUG=false
CORS_ORIGINS=["http://localhost:3000"]
CORS_ALLOW_VERCEL_PREVIEWS=true
API_BASE_URL=https://api.example.com
FRONTEND_URL=http://localhost:3000
PUBLIC_BASE_URL=http://localhost:8000

# Workers
# Set false for API-only processes. Run `uv run backend-workers` (or
# `python -m app.workers.runner`) in exactly one separate worker process when disabled.
RUN_BACKGROUND_WORKERS=true
CAMPAIGN_POLL_INTERVAL=5
AI_RESPONSE_DELAY_MS=2000

# Enrichment
ENABLE_AI_ENRICHMENT=true

# Demo landing page
DEMO_WORKSPACE_ID=your-demo-workspace-uuid
DEMO_AGENT_ID=your-demo-agent-uuid
DEMO_FROM_PHONE_NUMBER=+15551234567
DEMO_IP_RATE_LIMIT=15
DEMO_PHONE_RATE_LIMIT=9
# JSON array of E.164 phone numbers that bypass demo rate limits (for dev/QA only).
# Leave as [] in production. Anyone with a listed number can submit unlimited demo requests.
DEMO_RATE_LIMIT_BYPASS_PHONES=[]

# Stripe
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
STRIPE_PRICE_ID=price_your-monthly-subscription-price-id
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret

# Lead form
LEAD_FORM_IP_RATE_LIMIT=20
