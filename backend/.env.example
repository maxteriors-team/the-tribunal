# The Tribunal backend environment template.
# Copy to backend/.env for local development and replace blank secrets.
# Generate SECRET_KEY and ENCRYPTION_KEY with: openssl rand -hex 32

# Database
DATABASE_URL=postgresql+asyncpg://aicrm:aicrm_dev_password@localhost:5432/aicrm
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# Redis
REDIS_URL=redis://localhost:6379/0

# Security
SECRET_KEY=
ENCRYPTION_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
COOKIE_SECURE=false

# OpenAI
OPENAI_API_KEY=
OPENAI_OAUTH_ACCESS_TOKEN=
OPENAI_OAUTH_REFRESH_TOKEN=
OPENAI_OAUTH_ACCOUNT_ID=
OPENAI_OAUTH_CLIENT_ID=
OPENAI_OAUTH_REDIRECT_URI=
OPENAI_OAUTH_EXPIRES_AT=0
OPENAI_OAUTH_TOKEN_URL=https://auth.openai.com/oauth/token
OPENAI_OAUTH_ORIGINATOR=
OPENAI_OAUTH_USER_AGENT=
OPENAI_REALTIME_MODEL=gpt-realtime-2
OPENAI_ESTIMATE_RENDER_MODEL=gpt-image-2
OPENAI_REALTIME_CLIENT_SECRET_TTL_SECONDS=600
OPENAI_REALTIME_IDLE_TIMEOUT_MS=6000
OPENAI_CODEX_VOICE_ENABLED=false
OPENAI_TIMEOUT=60

# Telnyx
TELNYX_API_KEY=
TELNYX_WEBHOOK_SECRET=
TELNYX_PUBLIC_KEY=
SKIP_WEBHOOK_VERIFICATION=false
TELNYX_CONNECTION_ID=

# Text messaging provider selection
TEXT_MESSAGE_PROVIDER=telnyx

# Self-hosted Mac iMessage relay
MAC_RELAY_BASE_URL=
MAC_RELAY_TOKEN=
MAC_RELAY_WEBHOOK_TOKEN=
MAC_RELAY_BACKEND_WEBHOOK_URL=
MAC_RELAY_DEFAULT_SERVICE=imessage

# Cal.com
CALCOM_API_KEY=
CALCOM_WEBHOOK_SECRET=

# Jobber (field-service sync)
JOBBER_ACCESS_TOKEN=
JOBBER_API_VERSION=2023-11-15

# ElevenLabs
ELEVENLABS_API_KEY=

# xAI (Grok)
XAI_API_KEY=

# Resend
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@example.com
RESEND_FROM_NAME=Maxteriors
RESEND_WEBHOOK_SECRET=

# Expo Push Notifications
EXPO_ACCESS_TOKEN=

# Google Places API
GOOGLE_PLACES_API_KEY=

# gosom/google-maps-scraper
GOSOM_BASE_URL=
GOSOM_REQUEST_TIMEOUT_SECONDS=30.0
GOSOM_POLL_INTERVAL_SECONDS=5.0
GOSOM_POLL_MAX_WAIT_SECONDS=900.0
GOSOM_DEFAULT_DEPTH=1
GOSOM_DEFAULT_CONCURRENCY=4
GOSOM_DEFAULT_EMAIL_EXTRACTION=true
GOSOM_DEFAULT_EXTRA_REVIEWS=false
GOSOM_DEFAULT_LANG=en
GOSOM_DEFAULT_MAX_TIME_SECONDS=600

# Ad-library prospecting (Meta Ad Library + Google Ads Transparency)
# Pulls advertisers from public ad libraries to find consistent-but-not-testing
# advertisers as outbound prospects. See backend/docs/ad-library.md. The Meta
# token (ads_read) is a single-tenant/dev fallback; per-workspace credentials
# via a `meta_ad_library` WorkspaceIntegration are preferred. Never log it.
AD_LIBRARY_ENABLED=true
META_AD_LIBRARY_ACCESS_TOKEN=
META_AD_LIBRARY_API_VERSION=v22.0
META_AD_LIBRARY_BASE_URL=https://graph.facebook.com
META_AD_LIBRARY_RATE_LIMIT_PER_HOUR=180
META_AD_LIBRARY_REQUEST_TIMEOUT_SECONDS=30.0
META_AD_LIBRARY_DEFAULT_COUNTRY=US
# Config-gated third-party Meta fallback (Apify / ScrapeCreators / SerpApi).
META_THIRDPARTY_ENABLED=false
META_THIRDPARTY_PROVIDER=
META_THIRDPARTY_API_KEY=
META_THIRDPARTY_BASE_URL=
# In-house self-scrape of the public Ad Library (own the data source; no paid
# third party). Requires AD_LIBRARY_ALLOW_RAW_SCRAPE=true as the master switch.
# strategy: token_http (default, no browser) | headless (Playwright Chromium).
# A residential/ISP proxy is effectively required from datacenter IPs (Railway).
META_SELF_SCRAPE_ENABLED=false
META_SCRAPE_STRATEGY=token_http
META_SCRAPE_PROXY_URL=
META_SCRAPE_MIN_DELAY_SECONDS=2.0
META_SCRAPE_MAX_DELAY_SECONDS=5.0
META_SCRAPE_SESSION_TTL_SECONDS=1800
META_SCRAPE_RATE_LIMIT_PER_HOUR=40
# Meta internal GraphQL persisted-query doc ids used by the self-scrape path.
META_SCRAPE_SEARCH_DOC_ID=24922295957467452
META_SCRAPE_TYPEAHEAD_DOC_ID=9755915494515334
# Google Ads Transparency via SerpApi (no official API). Off by default.
GOOGLE_ADS_TRANSPARENCY_ENABLED=false
SERPAPI_API_KEY=
SERPAPI_BASE_URL=https://serpapi.com
# Hard wall around raw scraping (Meta ToS restricts it) + optional snapshot render.
AD_LIBRARY_ALLOW_RAW_SCRAPE=false
AD_LIBRARY_SNAPSHOT_RENDERING_ENABLED=false
# Ad-library worker enable flags + poll cadence.
AD_LIBRARY_DISCOVERY_WORKER_ENABLED=true
AD_LIBRARY_DISCOVERY_POLL_INTERVAL=15
AD_MONITOR_WORKER_ENABLED=true
AD_MONITOR_POLL_INTERVAL=300
PROSPECT_ENRICHMENT_WORKER_ENABLED=true
PROSPECT_ENRICHMENT_POLL_INTERVAL=30
PROSPECT_PROMOTION_WORKER_ENABLED=true
PROSPECT_PROMOTION_POLL_INTERVAL=30
# Optional config-gated email finder for prospect enrichment.
EMAIL_FINDER_PROVIDER=
EMAIL_FINDER_API_KEY=

# --- People discovery + buying signals (Apollo-parity) ---
# Web people-extraction discovery worker + crawl caps.
WEB_PEOPLE_DISCOVERY_WORKER_ENABLED=true
WEB_PEOPLE_DISCOVERY_POLL_INTERVAL=20
WEB_PEOPLE_MAX_PAGES_PER_DOMAIN=8
WEB_PEOPLE_MAX_PEOPLE_PER_DOMAIN=50
# Email reveal: pattern inference is always on; verification is opt-in.
# MX runs when enabled; SMTP probing only when explicitly turned on.
EMAIL_VERIFICATION_ENABLED=false
EMAIL_VERIFICATION_SMTP_ENABLED=false
EMAIL_VERIFICATION_SMTP_TIMEOUT_SECONDS=8.0
EMAIL_VERIFICATION_SMTP_FROM=verify@example.com
# Phone reveal: scrape the prospect's own website for a published business line.
PHONE_REVEAL_ENABLED=true
PHONE_REVEAL_MAX_PAGES=3
# Config-gated signal providers — empty key = provider disabled (no data).
HIRING_SIGNAL_API_KEY=
FUNDING_SIGNAL_API_KEY=

# App
DEBUG=false
ENVIRONMENT=development
CORS_ORIGINS=["http://localhost:3000"]
API_BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
PUBLIC_BASE_URL=http://localhost:8000

# Workers
RUN_BACKGROUND_WORKERS=true
CAMPAIGN_POLL_INTERVAL=5
AI_RESPONSE_DELAY_MS=2000
# Recurring-job materializer cadence (seconds). Hourly is plenty — generation
# runs days ahead of the due date.
RECURRING_JOB_POLL_INTERVAL=3600

# Enrichment
ENABLE_AI_ENRICHMENT=true

# Revenue/ROI estimation (blended AI costs used by dashboard revenue stats)
AI_COST_PER_CALL_USD=0.45
AI_COST_PER_SMS_USD=0.03

# Demo landing page
DEMO_WORKSPACE_ID=
DEMO_AGENT_ID=
DEMO_FROM_PHONE_NUMBER=
DEMO_IP_RATE_LIMIT=15
DEMO_PHONE_RATE_LIMIT=9
DEMO_RATE_LIMIT_BYPASS_PHONES=[]

# Stripe
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=

# Lead form
LEAD_FORM_IP_RATE_LIMIT=20

# Security - trusted proxies
TRUSTED_PROXIES=["127.0.0.1","::1"]

# Sentry
SENTRY_DSN=

# Prometheus metrics
METRICS_TOKEN=

# WebSocket connection limits
VOICE_BRIDGE_MAX_CONNECTIONS=100
VOICE_TEST_MAX_CONNECTIONS=20
VOICE_WORKSPACE_MAX_SESSIONS=10
VOICE_HEARTBEAT_INTERVAL_SECONDS=20
VOICE_PONG_TIMEOUT_SECONDS=40
VOICE_MAX_CALL_DURATION_SECONDS=1800

# Live call sentiment monitoring + escalation
VOICE_LIVE_SENTIMENT_ENABLED=true
VOICE_SENTIMENT_ESCALATION_THRESHOLD=-0.4
VOICE_SENTIMENT_SUSTAINED_TURNS=3
VOICE_SENTIMENT_SMOOTHING=0.5
VOICE_SENTIMENT_AUTO_TRANSFER=false
